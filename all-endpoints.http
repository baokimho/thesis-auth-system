@authHost = http://localhost:3001
@gatewayHost = http://localhost:3000
@resourceHost = http://localhost:4000

###
# AUTH SERVICE - HEALTH
GET {{authHost}}/auth/health

###
# AUTH SERVICE - JWT LOGIN
# @name jwtLogin
POST {{authHost}}/auth/jwt/login
Content-Type: application/json

{}

###
# AUTH SERVICE - JWT VERIFY (ACCESS TOKEN)
POST {{authHost}}/auth/jwt/verify
Content-Type: application/json

{
  "token": "{{jwtLogin.response.body.$.accessToken}}"
}

###
# AUTH SERVICE - JWT REFRESH
# @name jwtRefresh
POST {{authHost}}/auth/jwt/refresh
Content-Type: application/json

{
  "refreshToken": "{{jwtLogin.response.body.$.refreshToken}}"
}

###
# AUTH SERVICE - PASETO LOGIN
# @name pasetoLogin
POST {{authHost}}/auth/paseto/login
Content-Type: application/json

{}

###
# AUTH SERVICE - PASETO VERIFY (ACCESS TOKEN)
POST {{authHost}}/auth/paseto/verify
Content-Type: application/json

{
  "token": "{{pasetoLogin.response.body.$.accessToken}}"
}

###
# AUTH SERVICE - PASETO REFRESH
# @name pasetoRefresh
POST {{authHost}}/auth/paseto/refresh
Content-Type: application/json

{
  "refreshToken": "{{pasetoLogin.response.body.$.refreshToken}}"
}

###
# API GATEWAY - PUBLIC
GET {{gatewayHost}}/api/public

###
# API GATEWAY - JWT PROTECTED
GET {{gatewayHost}}/api/jwt-protected
Authorization: Bearer {{jwtLogin.response.body.$.accessToken}}

###
# API GATEWAY - PASETO PROTECTED
GET {{gatewayHost}}/api/paseto-protected
Authorization: Bearer {{pasetoLogin.response.body.$.accessToken}}

###
# API GATEWAY - JWT RESOURCE PROXY
# NOTE: Proxy config may need adjustment in api-gateway/src/proxy/resource.proxy.ts
GET {{gatewayHost}}/api/jwt-resource
Authorization: Bearer {{jwtLogin.response.body.$.accessToken}}

###
# API GATEWAY - PASETO RESOURCE PROXY
# NOTE: Proxy config may need adjustment in api-gateway/src/proxy/resource.proxy.ts
GET {{gatewayHost}}/api/paseto-resource
Authorization: Bearer {{pasetoLogin.response.body.$.accessToken}}

###
# RESOURCE SERVICE - PROFILE (DIRECT)
GET {{resourceHost}}/profile
x-user-id: 1
x-user-email: test@example.com

###
# RESOURCE SERVICE - ORDERS (DIRECT)
GET {{resourceHost}}/orders
x-user-id: 1
