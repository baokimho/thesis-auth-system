@authHost = http://localhost:3001
@gatewayHost = http://localhost:3000
@resourceHost = http://localhost:4000

# ============================================================
# Full token flows are separated by type:
#   jwt-flow.http    - JWT   : login → verify → protected → proxy → direct → refresh
#   paseto-flow.http - PASETO: login → verify → protected → proxy → direct → refresh
# ============================================================

###
# HEALTH CHECK
GET {{authHost}}/auth/health

###
# PUBLIC (no token required)
GET {{gatewayHost}}/api/public

