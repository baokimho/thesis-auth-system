@authHost = http://localhost:3001
@gatewayHost = http://localhost:3000
@pasetoEmail = paseto_user_test@example.com
@pasetoPassword = P@ssw0rd123!

# ============================================================
# PASETO LOGOUT FLOW
# Steps: Register → Login → Logout
# ============================================================

###
# STEP 1: Register
# @name pasetoLogoutRegister
POST {{gatewayHost}}/api/auth/paseto/register
Content-Type: application/json

{
  "email": "{{pasetoEmail}}",
  "password": "{{pasetoPassword}}"
}

###
# STEP 2: Login
# @name pasetoLogoutLogin
POST {{gatewayHost}}/api/auth/paseto/login
Content-Type: application/json

{
  "email": "{{pasetoEmail}}",
  "password": "{{pasetoPassword}}"
}

###
# STEP 3: Logout - revoke refresh token
POST {{gatewayHost}}/api/auth/paseto/logout
Content-Type: application/json

{
  "refreshToken": "{{pasetoLogoutLogin.response.body.$.refreshToken}}"
}
